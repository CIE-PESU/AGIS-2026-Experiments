# ─────────────────────────────────────────────────────────────────────────────
# AGIS Backend — Environment Variables
# Copy this to .env and fill in all values before running.
# NEVER commit .env to git. Only .env.example belongs in the repo.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME="AGIS Entrepreneurship Coach Platform"
APP_VERSION="1.0.0"
ENVIRONMENT=development   # development | staging | production
DEBUG=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agis
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# PES Auth API
PES_AUTH_URL=https://auth.pes.edu/api/v1/validate
PES_AUTH_TIMEOUT_SECONDS=5.0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# CORS — comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Internal Worker Secret — shared between backend and worker services
WORKER_INTERNAL_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_WORKER_SECRET

# Rate Limiting
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=60

# Payload
MAX_REQUEST_BODY_BYTES=1048576
